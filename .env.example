# Copy this file to .env and fill in your real API keys.
# Never commit .env to version control.

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Default model identifier
LLM_MODEL=gpt-4o-mini
MAX_LLM_PROMPT_CHARS=80000
MAX_LLM_OUTPUT_TOKENS=1800
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=32

# Supabase
# Backend-only values. Never expose SUPABASE_SERVICE_ROLE_KEY in the frontend.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Backend security
# Set this in production and pass it from the Next.js server proxy as X-API-Key.
BACKEND_API_KEY=replace_with_long_random_secret
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MAX_REQUEST_BYTES=2000000
MAX_UPLOAD_BYTES=8000000
MAX_UPLOAD_FILES=5
MAX_EXTRACTED_TEXT_CHARS=180000
MAX_RAG_CHUNKS=120
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
